# ForzaKit — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Supabase project URL (found in: Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in client-side code — read-only by design)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Feature flags
# Set to 'true' to enable the login/auth flow. Leave 'false' to run in demo mode (no login required).
VITE_AUTH_ENABLED=false
