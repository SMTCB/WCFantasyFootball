# ForzaKit — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to 'true' to enable the login/auth flow.
# Leave 'false' to run in demo mode (no login required — for showcasing).
VITE_AUTH_ENABLED=false

# ── CI / GitHub Actions secrets ───────────────────────────────────────────────
# These are NOT needed in .env.local — add them in:
#   GitHub → repo → Settings → Secrets and variables → Actions → New repository secret
#
#   VITE_SUPABASE_URL        (same value as above — needed for vite build in CI)
#   VITE_SUPABASE_ANON_KEY   (same value as above — needed for vite build in CI)
#
# For the manual DB migration workflow (.github/workflows/migrate.yml) add:
#   SUPABASE_ACCESS_TOKEN    (Personal access token from app.supabase.com/account/tokens)
#   SUPABASE_PROJECT_REF     (e.g. sssmvihxtqtohisghjet)
#   SUPABASE_DB_PASSWORD     (DB password from Supabase dashboard → Project Settings → Database)

# ── E2E testing ───────────────────────────────────────────────────────────────
# SUPABASE_URL and SUPABASE_ANON_KEY are used by Playwright E2E specs and
# scripts/e2e-setup.mjs to connect directly to Supabase. Without these the
# tests fall back to the project's own Supabase instance (development only).
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_PROJECT_REF=your-project-id

# ── E2E testing against a deployed preview ────────────────────────────────────
# Set this to override the local dev server (used in CI against Vercel previews):
# PLAYWRIGHT_BASE_URL=https://your-preview-url.vercel.app

# ── Docker / local dev ────────────────────────────────────────────────────────
# Used by docker-compose.yml. VITE_* vars above are also read as build args.
# POSTGRES_PASSWORD=postgres              # local Postgres password (docker-compose db service)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_URL=https://your-project-id.supabase.co
# EDGE_FUNCTION=sync-fixtures             # which function the docker-compose functions service runs

# ── Edge Function secrets (Supabase secret store, NOT in .env.local) ─────────
# Set via:  npx supabase secrets set KEY=value --project-ref sssmvihxtqtohisghjet
# List via: npx supabase secrets list --project-ref sssmvihxtqtohisghjet
# Never put real values in this file — it is committed to git.
#
# Required for production:
# SUPABASE_JWT_SECRET=...           # Auto-set by Supabase; used by _shared/auth.ts HMAC guard
# FORZA_ACCESS_TOKEN=...            # Forza Football API — sync-fixtures, sync-players, ingest-match-events
# GROQ_API_KEY=...                  # Groq LLM — generate-frontpage-edition (Clubhouse newspaper)
# RAPIDAPI_TENNIS_KEY=...           # RapidAPI tennis-api-atp-wta-itf — sync-tennis-players (50 req/day free)
# STRIPE_SECRET_KEY=sk_live_...     # Stripe secret — purchase-coins (not yet active; set when Stripe is ready)
# STRIPE_WEBHOOK_SECRET=whsec_...   # Stripe webhook signing secret — purchase-coins webhook route
#
# Development / staging only (never set in production):
# MOCK_PAYMENTS=true                # purchase-coins: credits coins directly, no Stripe call or webhook needed

# ── Environment targets ───────────────────────────────────────────────────────
# prod:    VITE_SUPABASE_URL=https://sssmvihxtqtohisghjet.supabase.co (set in Vercel)
# staging: provision a second Supabase project; set VITE_SUPABASE_URL to its URL
# local:   run `npx supabase start` then use the printed URL + keys, OR docker compose up
