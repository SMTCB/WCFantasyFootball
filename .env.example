# ForzaKit — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to 'true' to enable the login/auth flow.
# Leave 'false' to run in demo mode (no login required — for showcasing).
VITE_AUTH_ENABLED=false

# ── CI / GitHub Actions secrets ───────────────────────────────────────────────
# These are NOT needed in .env.local — add them in:
#   GitHub → repo → Settings → Secrets and variables → Actions → New repository secret
#
#   VITE_SUPABASE_URL        (same value as above — needed for vite build in CI)
#   VITE_SUPABASE_ANON_KEY   (same value as above — needed for vite build in CI)
#
# For the manual DB migration workflow (.github/workflows/migrate.yml) add:
#   SUPABASE_ACCESS_TOKEN    (Personal access token from app.supabase.com/account/tokens)
#   SUPABASE_PROJECT_REF     (e.g. sssmvihxtqtohisghjet)
#   SUPABASE_DB_PASSWORD     (DB password from Supabase dashboard → Project Settings → Database)

# ── E2E testing against a deployed preview ────────────────────────────────────
# Set this to override the local dev server (used in CI against Vercel previews):
# PLAYWRIGHT_BASE_URL=https://your-preview-url.vercel.app
